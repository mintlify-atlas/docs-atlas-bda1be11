            "pages": ["components/confirm-modal"]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Services",
            "pages": ["api/auth-service", "api/board-service", "api/column-service", "api/task-service"]
          },
          {
            "group": "Guards & Interceptors",
