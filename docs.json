{
  "$schema": "https://mintlify.com/docs.json",
  "name": "TaskFlow Angular",
  "theme": "palm",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#2563eb"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/JoelVM2/TaskFlowAngular"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/JoelVM2/TaskFlowAngular"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
